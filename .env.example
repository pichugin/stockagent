# Alpaca market-data credentials (US equities). Free tier:
#   https://alpaca.markets/  ->  create an API key (paper account is fine for data)
# If these are absent, StockAgent automatically falls back to yahoo-finance2
# for US symbols too, so the app still runs without an Alpaca account.
ALPACA_KEY=
ALPACA_SECRET=

# OpenAI API key — powers the Phase 6 LLM narration layer (the `explain`
# command). If absent, StockAgent runs fully on the deterministic engine and
# prints deterministic summaries with an "AI explanation unavailable" note, so
# the tool works without an OpenAI account. The provider/model are chosen in
# watchlist.yaml (`llm:` block); only the secret lives here.
OPENAI_API_KEY=

# Optional: override the SQLite file location (default: ./stockagent.db)
# STOCKAGENT_DB=./stockagent.db

# Optional: override the watchlist config path (default: ./watchlist.yaml)
# STOCKAGENT_WATCHLIST=./watchlist.yaml

# Testing only: force every FX fetch to fail, to exercise the stale-rate
# fallback (portfolio reads serve the last cached rate, flagged ⚠ STALE).
# STOCKAGENT_FX_FORCE_FAIL=1
